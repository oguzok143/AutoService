<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:AutoService.Models"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="AutoService.Views.WorksWindow"
        x:DataType="models:WorksWindowViewModel"
        Title="WorksWindow">

        <StackPanel>
                <DataGrid ItemsSource="{Binding SelectedWorks}" >
                        <DataGrid.Columns>
                                <DataGridCheckBoxColumn Header="Выбрано" Binding="{Binding IsSelected}"/>
                                <DataGridTextColumn Header="Назавние работы" Binding="{Binding Work.WorkName}" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Цена" Binding="{Binding Work.Price}" IsReadOnly="True"/>
                        </DataGrid.Columns>
                </DataGrid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Bottom">
                        <Button Content="Расчитать стоимость" Command="{Binding OpenReceiptWindowCommand}"/>
                </StackPanel>
        </StackPanel>
</Window>
